{
  "manifest_version": 3,
  "name": "PhishGuard Protection",
  "version": "1.0",
  "description": "Blocks phishing URLs detected by PhishGuard",
  "permissions": [
    "tabs",
    "activeTab", 
    "scripting",
    "storage",
    "declarativeNetRequest",
    "notifications",
    "webNavigation"
  ],
  "host_permissions": [
    "http://localhost:8080/*",
    "http://localhost:8081/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "PhishGuard Active",
    "default_popup": "popup.html"
  }
}
